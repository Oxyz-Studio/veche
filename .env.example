# ── Copy this file to `.env` and fill in the values. `.env` is gitignored. ──
# I (Claude) will load these via python-dotenv and NEVER print the values.

# 🔴 BLOCKING — needed to run the swarm (Flash Computer-Use) + the operator (Gemma 4)
#   Get: https://aistudio.google.com/app/api-keys  → "Create API key"
GEMINI_API_KEY=

# 🟠 Needed for node-identity embeddings (screenshots). Free tokens on signup.
#   Get: https://dashboard.voyageai.com → API Keys  (or ask at the MongoDB/Voyage table)
VOYAGE_API_KEY=

# 🟠 The shared memory (append-log + consolidated graph + vector index).
#   Easiest: ask the MongoDB table for the "Atlas Sandbox on GCP" connection string.
#   Or self-serve: cloud.mongodb.com → free M0 cluster → Connect → Drivers → copy URI.
MONGODB_URI=

# 🟢 LATER — only for hosting the demo (Guacamole + OpenEMR). We dev locally first.
#   Claim $200: DO table or https://do-hacker-guide-uijyg.ondigitalocean.app
#   Token: cloud.digitalocean.com/account/api/tokens → Generate (write scope)
DIGITALOCEAN_TOKEN=
